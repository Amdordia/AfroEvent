@model AfroEvent.ViewModels.ParticipantInscriptionViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-warning text-dark text-center py-4 rounded-top-4">
                    <h3 class="fw-bold mb-1">
                        <i class="bi bi-person-plus-fill me-2"></i>
                        Étape 1 : Inscription participant
                    </h3>
                    <p class="mb-0 mt-2">Remplissez le formulaire pour réserver votre place.</p>
                    <p class="fw-bold mb-3">Événement : @ViewBag.EventName</p>
                    <div class="d-flex justify-content-center gap-2 mt-2">
                        <span class="badge bg-dark">1. Inscription</span>
                        <span class="badge bg-light text-dark">2. Paiement</span>
                        <span class="badge bg-light text-dark">3. Billet</span>
                    </div>
                </div>

                <div class="card-body p-5">
                    <form asp-action="SInscrire" asp-route-nom="@ViewBag.EventName" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="nom" value="@ViewBag.EventName" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="NomComplet" class="form-label fw-semibold"></label>
                            <input asp-for="NomComplet" class="form-control rounded-3" placeholder="Ex : Moussa Traoré" />
                            <span asp-validation-for="NomComplet" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control rounded-3" placeholder="exemple@email.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TypeP" class="form-label fw-semibold"></label>
                            <select asp-for="TypeP" asp-items="Html.GetEnumSelectList<AfroEvent.ViewModels.TypePass>()" class="form-select rounded-3">
                                <option value="">-- Choisir un type de pass --</option>
                            </select>
                            <span asp-validation-for="TypeP" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="AccepteConditions" class="form-check-input" />
                            <label asp-for="AccepteConditions" class="form-check-label">
                                J'accepte les conditions d'utilisation
                            </label>
                            <br />
                            <span asp-validation-for="AccepteConditions" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn bg-warning text-dark fw-bold rounded-pill w-100 py-2">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            Valider mon inscription
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
