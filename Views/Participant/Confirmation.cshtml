@{
    ViewData["Title"] = "Confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center" style="width: 70px; height: 70px; font-size: 2rem;">
                            ✓
                        </div>
                        <h1 class="fw-bold mt-3">Étape 2 : Paiement</h1>
                        <p class="text-muted">Votre réservation est bien enregistrée et votre place est désormais sécurisée.</p>
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <span class="badge bg-success">1. Inscription</span>
                            <span class="badge bg-dark">2. Paiement</span>
                            <span class="badge bg-light text-dark">3. Billet</span>
                        </div>
                    </div>

                    <div class="alert alert-success">
                        <strong>Merci @ViewBag.ParticipantName !</strong> Votre inscription pour <strong>@ViewBag.EventName</strong> a été validée.
                    </div>

                    <div class="row g-4 mt-2">
                        <div class="col-md-6">
                            <div class="border rounded-4 p-4 h-100">
                                <h5 class="fw-bold">Détails de votre réservation</h5>
                                <ul class="mb-0">
                                    <li><strong>Événement :</strong> @ViewBag.EventName</li>
                                    <li><strong>Pass :</strong> @ViewBag.ParticipantPass</li>
                                    <li><strong>Email :</strong> @ViewBag.ParticipantEmail</li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded-4 p-4 h-100 bg-dark text-light">
                                <h5 class="fw-bold">Paiement sécurisé</h5>
                                <p class="text-light opacity-75">Paiement simulé en mode test pour illustrer le parcours complet.</p>
                                <div class="mb-3">
                                    <label class="form-label">Nom sur la carte</label>
                                    <input class="form-control" value="@ViewBag.ParticipantName" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Numéro de carte</label>
                                    <input class="form-control" value="4242 4242 4242 4242" />
                                </div>
                                <a asp-action="PayGet" asp-controller="Participant" asp-route-nom="@ViewBag.EventName" class="btn btn-warning text-dark fw-bold w-100 d-inline-block text-center">Payer maintenant</a>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 border rounded-4 p-4 bg-light">
                        <h5 class="fw-bold">Votre e-billet</h5>
                        <p class="text-muted mb-3">Le QR code d’e-billet sera généré après validation du paiement.</p>
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-white border rounded p-3">
                                <i class="bi bi-qr-code-scan" style="font-size: 3rem;"></i>
                            </div>
                            <div>
                                <p class="mb-1"><strong>Nom :</strong> @ViewBag.ParticipantName</p>
                                <p class="mb-0"><strong>Événement :</strong> @ViewBag.EventName</p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark">Retour à l'accueil</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
