@model AfroEvent.ViewModels.ProjetSoumissionViewModel
@{
    ViewData["Title"] = "Soumettre un Projet";
}

<div class="container mt-5">
    <h2>Soumission de Sujet de Projet M1</h2>
    <hr />

    @if (TempData["SuccesMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccesMessage"]
        </div>
    }

    <form asp-action="Creer" method="post" class="card p-4 shadow-sm">
        
        <div class="mb-3">
            <label asp-for="Titre" class="form-label fw-bold"></label>
            <input asp-for="Titre" class="form-control" />
            <!-- TODO 1 -->
            <span asp-validation-for="Titre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold"></label>
            <!-- TODO 2  -->
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ChefEquipe" class="form-label fw-bold"></label>
            <input asp-for="ChefEquipe" class="form-control" />
            <span asp-validation-for="ChefEquipe" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EmailContact" class="form-label fw-bold"></label>
            <input asp-for="EmailContact" class="form-control" />
            <span asp-validation-for="EmailContact" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="BudgetEstime" class="form-label fw-bold"></label>
            <input asp-for="BudgetEstime" type="number" class="form-control" />
            <span asp-validation-for="BudgetEstime" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-bold">Soumettre le projet</button>
    </form>
</div>