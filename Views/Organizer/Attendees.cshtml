@model IEnumerable<AfroEvent.ViewModels.AttendeeViewModel>
@{
    ViewData["Title"] = "Suivi des Inscrits & Check-in";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between pb-3 mb-4 border-bottom">
    <div>
        <div class="d-flex align-items-center gap-2 mb-1">
            <a asp-controller="Organizer" asp-action="Events" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
            <h2 class="fw-bold text-dark mb-0">Inscrits & Contrôle d'Accès</h2>
        </div>
        <p class="text-muted mb-0">Événement : <strong class="text-dark">@ViewBag.EventTitle</strong></p>
    </div>
    <div class="mt-3 mt-md-0 d-flex gap-2">
        <button class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#qrScanModal">
            <i class="bi bi-qr-code-scan me-1"></i> Scanner un QR Code (Jour J)
        </button>
        <button class="btn btn-outline-dark shadow-sm">
            <i class="bi bi-download me-1"></i> Exporter CSV
        </button>
    </div>
</div>

<div class="modal fade" id="qrScanModal" tabindex="-1" aria-labelledby="qrScanModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header bg-dark text-white rounded-top-4 py-3">
                <h5 class="modal-header-title mb-0 fw-bold" id="qrScanModalLabel">
                    <i class="bi bi-camera-fill text-warning me-2"></i>Scanner de QR Code (Mobile/Web)
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <div class="border border-2 border-dashed border-warning rounded-4 p-4 mb-3 bg-light position-relative">
                    <i class="bi bi-qr-code fs-1 text-warning d-block mb-2"></i>
                    <p class="small text-muted mb-0">Orientez l'appareil photo du smartphone vers le QR Code sur le billet du participant.</p>
                </div>
                <div class="input-group mb-3">
                    <input type="text" class="form-control" placeholder="Ou saisissez le code manuellement (ex: AFRO-TKT-...)" id="manualQrInput">
                    <button class="btn btn-afro" type="button" onclick="simulateCheckIn()">Valider</button>
                </div>
                <div id="scanResultAlert" class="alert alert-success d-none mb-0" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i><strong>Entrée validée !</strong> Participant : Aminata Diallo
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 bg-white">
    <div class="card-header bg-transparent border-0 pt-3 px-4 d-flex align-items-center justify-content-between">
        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-people-fill text-primary me-2"></i>Liste des Inscrits (@Model.Count())</h5>
        <div class="input-group style-search" style="max-width: 300px;">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control bg-light border-start-0" placeholder="Filtrer par nom ou email...">
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Participant</th>
                        <th>Téléphone</th>
                        <th>Date d'inscription</th>
                        <th>Paiement</th>
                        <th>Statut Présence</th>
                        <th>Heure du Scan</th>
                        <th class="pe-4 text-end">Billet</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attendee in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@attendee.ParticipantName</div>
                                <div class="small text-muted">@attendee.Email</div>
                            </td>
                            <td class="small">
                                <i class="bi bi-telephone text-muted me-1"></i>@attendee.PhoneNumber
                            </td>
                            <td class="small">
                                @attendee.RegistrationDate.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                @if (attendee.IsPaid)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success"><i class="bi bi-check-circle-fill me-1"></i>Payé</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning"><i class="bi bi-clock me-1"></i>En attente</span>
                                }
                            </td>
                            <td>
                                @if (attendee.IsPresent)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary fw-bold"><i class="bi bi-patch-check-fill me-1"></i>Présent</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary">Non scanné</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @(attendee.ScanDate.HasValue ? attendee.ScanDate.Value.ToString("HH:mm:ss") : "-")
                            </td>
                            <td class="pe-4 text-end">
                                <span class="badge bg-light text-dark font-monospace border">@attendee.QrCodeHash</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function simulateCheckIn() {
            const resultAlert = document.getElementById('scanResultAlert');
            resultAlert.classList.remove('d-none');
            setTimeout(() => {
                resultAlert.classList.add('d-none');
            }, 3000);
        }
    </script>
}
