@model IEnumerable<AfroEvent.ViewModels.OrganizerEventSummaryViewModel>
@{
    ViewData["Title"] = "Gestion des Événements";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between pb-3 mb-4 border-bottom">
    <div>
        <h2 class="fw-bold text-dark mb-1">
            <i class="bi bi-kanban-fill text-primary me-2"></i>Gestion de mes Événements
        </h2>
        <p class="text-muted mb-0">Consultez, modifiez et suivez l'ensemble des événements que vous organisez.</p>
    </div>
    <div class="mt-3 mt-md-0">
        <a asp-controller="Events" asp-action="Create" class="btn btn-afro shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Créer un nouvel événement
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 bg-white mb-4">
    <div class="card-body p-3">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-start-0" placeholder="Rechercher un événement par titre ou lieu...">
                </div>
            </div>
            <div class="col-6 col-md-3">
                <select class="form-select bg-light">
                    <option value="">Tous les statuts</option>
                    <option value="Publié">Publié</option>
                    <option value="Brouillon">Brouillon</option>
                    <option value="Terminé">Terminé</option>
                </select>
            </div>
            <div class="col-6 col-md-3">
                <select class="form-select bg-light">
                    <option value="">Toutes les catégories</option>
                    <option value="Hackathon">Hackathon</option>
                    <option value="Bootcamp">Bootcamp</option>
                    <option value="Conférence">Conférence</option>
                </select>
            </div>
            <div class="col-12 col-md-1 text-end">
                <button class="btn btn-outline-secondary w-100" title="Réinitialiser"><i class="bi bi-arrow-counterclockwise"></i></button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 bg-white">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Titre de l'événement</th>
                        <th>Catégorie</th>
                        <th>Date & Heure</th>
                        <th>Prix Billet</th>
                        <th>Inscrits</th>
                        <th>Taux de remplissage</th>
                        <th>Statut</th>
                        <th class="pe-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model)
                    {
                        var fillRate = evt.MaxCapacity > 0 ? (int)Math.Round((double)evt.RegisteredCount / evt.MaxCapacity * 100) : 0;
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-dark fs-6">@evt.Title</div>
                                <div class="small text-muted"><i class="bi bi-geo-alt text-danger me-1"></i>@evt.LocationAddress</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border">@evt.CategoryName</span>
                            </td>
                            <td class="small">
                                <div class="fw-semibold text-dark">@evt.StartDate.ToString("dd MMMM yyyy")</div>
                                <div class="text-muted"><i class="bi bi-clock me-1"></i>@evt.StartDate.ToString("HH:mm")</div>
                            </td>
                            <td>
                                @if (evt.TicketPrice > 0)
                                {
                                    <span class="fw-bold text-dark">@evt.TicketPrice.ToString("N0") FCFA</span>
                                }
                                else
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success fw-bold">Gratuit</span>
                                }
                            </td>
                            <td>
                                <span class="fw-bold">@evt.RegisteredCount</span> <span class="text-muted small">/ @evt.MaxCapacity</span>
                            </td>
                            <td style="min-width: 150px;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 8px;">
                                        <div class="progress-bar @(fillRate >= 90 ? "bg-danger" : fillRate >= 60 ? "bg-warning" : "bg-success")"
                                             role="progressbar" style="width: @fillRate%"></div>
                                    </div>
                                    <span class="small fw-bold">@fillRate%</span>
                                </div>
                            </td>
                            <td>
                                @if (evt.Status == "Publié")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="bi bi-check-circle-fill me-1"></i>Publié</span>
                                }
                                else if (evt.Status == "Brouillon")
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1"><i class="bi bi-pause-circle-fill me-1"></i>Brouillon</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-2 py-1">Terminé</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light border dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        Gérer
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Events" asp-action="Details" asp-route-id="@evt.Id">
                                                <i class="bi bi-eye text-primary me-2"></i> Page publique
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Organizer" asp-action="Attendees" asp-route-id="@evt.Id">
                                                <i class="bi bi-people-fill text-info me-2"></i> Inscrits & Check-in
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Events" asp-action="Edit" asp-route-id="@evt.Id">
                                                <i class="bi bi-pencil-square text-warning me-2"></i> Modifier l'événement
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger" href="#">
                                                <i class="bi bi-trash me-2"></i> Supprimer
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
