@model AfroEvent.ViewModels.AdminDashboardViewModel

<div class="card border-0 shadow-sm rounded-4" style="background: white;">
    <div class="card-header bg-white py-3 border-0 d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
            <span class="p-2 rounded-3 text-warning d-flex align-items-center justify-content-center" style="background-color: rgba(255, 184, 0, 0.15); width: 38px; height: 38px;">
                <i class="bi bi-shield-check fs-5"></i>
            </span>
            <h5 class="fw-bold mb-0 text-dark">Espace Modération des Événements</h5>
        </div>
        <span class="badge bg-dark bg-opacity-75 text-warning px-3 py-2 rounded-pill">Contrôle Qualité & Sécurité</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.EvenementsEnModeration.Any())
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-calendar-x fs-1 text-secondary d-block mb-2"></i>
                <p class="mb-0 fw-semibold">Aucun événement à modérer pour le moment.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        <tr>
                            <th class="ps-4 py-3">Événement / Catégorie</th>
                            <th class="py-3">Organisateur</th>
                            <th class="py-3">Tarif ticket</th>
                            <th class="py-3">Remplissage / Capacité</th>
                            <th class="py-3">Statut actuel</th>
                            <th class="text-end pe-4 py-3">Actions de modération</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 0.85rem;">
                        @foreach (var ev in Model.EvenementsEnModeration)
                        {
                            var percent = (int)((double)ev.PlacesReservees / ev.CapaciteMax * 100);
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="fw-bold text-dark fs-6">@ev.Titre</div>
                                    <div class="d-flex align-items-center gap-2 mt-1">
                                        <span class="badge bg-light text-secondary border rounded-pill px-2">@ev.Categorie</span>
                                        <span class="text-muted"><i class="bi bi-calendar3 me-1"></i>@ev.DateDebut.ToString("dd MMM yyyy")</span>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="fw-semibold text-dark"><i class="bi bi-person-badge-fill text-muted me-1"></i>@ev.OrganisateurNom</span>
                                </td>
                                <td class="py-3">
                                    @if (ev.PrixTicket == 0)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success fw-bold px-2 py-1 rounded">Gratuit</span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-dark">@ev.PrixTicket.ToString("N0") <small class="text-muted fw-normal">FCFA</small></span>
                                    }
                                </td>
                                <td class="py-3" style="min-width: 150px;">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="fw-semibold text-dark">@ev.PlacesReservees / @ev.CapaciteMax</span>
                                        <span class="text-muted small">@percent%</span>
                                    </div>
                                    <div class="progress rounded-pill" style="height: 6px; background-color: #f1f5f9;">
                                        <div class="progress-bar @(percent > 80 ? "bg-danger" : "bg-warning")" role="progressbar" style="width: @percent%" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    @if (ev.Statut == "Publié")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-2 py-1fw-semibold"><i class="bi bi-check-circle me-1"></i>Publié</span>
                                    }
                                    else if (ev.Statut == "En attente")
                                    {
                                        <span class="badge bg-warning bg-opacity-15 text-warning-emphasis border border-warning border-opacity-25 rounded-pill px-2 py-1 fw-semibold"><i class="bi bi-hourglass-split me-1"></i>En attente</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-2 py-1 fw-semibold"><i class="bi bi-slash-circle me-1"></i>Bloqué</span>
                                    }
                                </td>
                                <td class="text-end pe-4 py-3">
                                    @if (ev.Statut == "En attente")
                                    {
                                        <div class="d-inline-flex gap-2">
                                            <form asp-action="ValiderEvenement" asp-route-id="@ev.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-orange btn-sm fw-bold">
                                                    Valider
                                                </button>
                                            </form>
                                            <form asp-action="BloquerEvenement" asp-route-id="@ev.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger btn-sm fw-semibold">
                                                    Bloquer
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else if (ev.Statut == "Publié")
                                    {
                                        <form asp-action="BloquerEvenement" asp-route-id="@ev.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm fw-semibold">
                                                <i class="bi bi-pause-circle me-1"></i> Suspendre
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="ValiderEvenement" asp-route-id="@ev.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-orange btn-sm fw-semibold">
                                                Débloquer
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
