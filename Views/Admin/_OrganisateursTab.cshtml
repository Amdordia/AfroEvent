@model AfroEvent.ViewModels.AdminDashboardViewModel

<div class="card border-0 shadow-sm rounded-4" style="background: white;">
    <div class="card-header bg-white py-3 border-0 d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
            <span class="p-2 rounded-3 text-warning d-flex align-items-center justify-content-center" style="background-color: rgba(255, 184, 0, 0.15); width: 38px; height: 38px;">
                <i class="bi bi-person-badge fs-5"></i>
            </span>
            <h5 class="fw-bold mb-0 text-dark">Gestion & Validation des Organisateurs</h5>
        </div>
        <span class="badge bg-warning bg-opacity-20 text-warning-emphasis px-3 py-2 rounded-pill fw-bold">@Model.OrganisateursEnAttente.Count demande(s) en attente</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.OrganisateursEnAttente.Any())
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-check2-circle fs-1 text-success d-block mb-3"></i>
                <h6 class="fw-bold text-dark mb-1">Excellent !</h6>
                <p class="mb-0 small text-secondary">Toutes les demandes d'organisateurs ont été traitées.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                        <tr>
                            <th class="ps-4 py-3">Organisation / Représentant</th>
                            <th class="py-3">Contact info</th>
                            <th class="py-3">Date de demande</th>
                            <th class="py-3">Statut actuel</th>
                            <th class="text-end pe-4 py-3">Actions de validation</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 0.85rem;">
                        @foreach (var org in Model.OrganisateursEnAttente)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle text-white fw-bold d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; background-color: #111622; border: 2px solid #ffb800;">
                                            @org.NomOrganisation.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <span class="fw-bold text-dark fs-6 d-block">@org.NomOrganisation</span>
                                            <small class="text-muted"><i class="bi bi-person me-1"></i>@org.NomComplet</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <div class="d-flex flex-column gap-1">
                                        <div><i class="bi bi-envelope text-muted me-1"></i>@org.Email</div>
                                        <div class="text-muted"><i class="bi bi-telephone text-muted me-1"></i>@org.Telephone</div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="text-muted"><i class="bi bi-calendar-event me-1"></i>@org.DateDemande.ToString("dd MMM yyyy à HH:mm")</span>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-warning bg-opacity-15 text-warning-emphasis border border-warning border-opacity-25 rounded-pill px-2 py-1 fw-semibold">
                                        <i class="bi bi-clock me-1"></i>@org.Statut
                                    </span>
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <div class="d-inline-flex gap-2">
                                        <form asp-action="ApprouverOrganisateur" asp-route-id="@org.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-orange btn-sm fw-bold">
                                                <i class="bi bi-check-lg me-1"></i> Approuver
                                            </button>
                                        </form>
                                        <form asp-action="RejeterOrganisateur" asp-route-id="@org.Id" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm fw-semibold">
                                                <i class="bi bi-x-lg me-1"></i> Refuser
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
