@model AfroEvent.ViewModels.EventCreateViewModel
@{
    ViewData["Title"] = "Créer un événement";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <h1 class="fw-bold mb-3">Créer un événement</h1>
                    <p class="text-muted">Aidez l’organisateur à renseigner les informations de base, la logistique, la billetterie et la catégorie en quelques étapes.</p>

                    <div class="d-flex justify-content-between mb-4">
                        <span class="step-pill active" data-step-pill="1">1. Informations de base</span>
                        <span class="step-pill" data-step-pill="2">2. Logistique</span>
                        <span class="step-pill" data-step-pill="3">3. Billetterie et catégorie</span>
                    </div>

                    <form asp-action="Create" method="post" class="mt-4">
                        <div class="step-pane" data-step="1">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Name" class="form-label"></label>
                                    <input asp-for="Name" class="form-control" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Category" class="form-label"></label>
                                    <input asp-for="Category" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="ShortDescription" class="form-label"></label>
                                    <input asp-for="ShortDescription" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="Description" class="form-label"></label>
                                    <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="step-pane d-none" data-step="2">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label asp-for="Program" class="form-label"></label>
                                    <textarea asp-for="Program" rows="4" class="form-control" placeholder="Ex : 9h00 - Accueil, 10h30 - Ateliers"></textarea>
                                </div>
                                <div class="col-12">
                                    <label asp-for="Speakers" class="form-label"></label>
                                    <input asp-for="Speakers" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Location" class="form-label"></label>
                                    <input asp-for="Location" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="StartDate" class="form-label"></label>
                                    <input asp-for="StartDate" class="form-control" type="date" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="Logistics" class="form-label"></label>
                                    <input asp-for="Logistics" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="step-pane d-none" data-step="3">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Price" class="form-label"></label>
                                    <input asp-for="Price" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Capacity" class="form-label"></label>
                                    <input asp-for="Capacity" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Latitude" class="form-label"></label>
                                    <input asp-for="Latitude" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Longitude" class="form-label"></label>
                                    <input asp-for="Longitude" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between gap-2 mt-4">
                            <button type="button" class="btn btn-outline-dark d-none" id="prevStep">Précédent</button>
                            <div class="ms-auto d-flex gap-2">
                                <button type="button" class="btn btn-warning text-dark fw-bold" id="nextStep">Étape suivante</button>
                                <button type="submit" class="btn btn-warning text-dark fw-bold d-none" id="submitStep">Publier l'événement</button>
                                <a asp-action="Index" class="btn btn-outline-dark">Retour</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const stepPills = document.querySelectorAll('.step-pill');
        const stepPanes = document.querySelectorAll('.step-pane');
        const nextButton = document.getElementById('nextStep');
        const prevButton = document.getElementById('prevStep');
        const submitButton = document.getElementById('submitStep');
        let currentStep = 1;

        function updateStep() {
            stepPanes.forEach(pane => pane.classList.toggle('d-none', Number(pane.dataset.step) !== currentStep));
            stepPills.forEach(pill => pill.classList.toggle('active', Number(pill.dataset.stepPill) === currentStep));
            prevButton.classList.toggle('d-none', currentStep === 1);
            nextButton.classList.toggle('d-none', currentStep === 3);
            submitButton.classList.toggle('d-none', currentStep !== 3);
        }

        nextButton.addEventListener('click', () => {
            if (currentStep < 3) {
                currentStep += 1;
                updateStep();
            }
        });

        prevButton.addEventListener('click', () => {
            if (currentStep > 1) {
                currentStep -= 1;
                updateStep();
            }
        });

        updateStep();
    </script>
}
