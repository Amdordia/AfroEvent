@model AfroEvent.ViewModels.EventFormViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="position-relative rounded-4 overflow-hidden shadow-lg mb-4 bg-dark text-white">
    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
    {
        <img src="@Model.CoverImageUrl" class="w-100 object-fit-cover opacity-50" style="height: 380px;" alt="@Model.Title" />
    }
    else
    {
        <div class="w-100 bg-secondary bg-gradient opacity-50" style="height: 380px;"></div>
    }
    
    <div class="position-absolute bottom-0 start-0 w-100 p-4 p-md-5 bg-gradient-to-t">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <span class="badge bg-warning text-dark fw-bold fs-6">@Model.CategoryName</span>
            <span class="badge bg-danger text-white fw-bold fs-6 badge-realtime">
                <i class="bi bi-broadcast me-1"></i>En direct : 15 places restantes !
            </span>
        </div>
        <h1 class="display-5 fw-bold mb-2">@Model.Title</h1>
        <p class="fs-5 text-white-50 mb-0"><i class="bi bi-geo-alt-fill text-warning me-2"></i>@Model.LocationAddress</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-8">
        
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
            <h4 class="fw-bold text-dark mb-3"><i class="bi bi-file-text-fill text-warning me-2"></i>À propos de cet événement</h4>
            <p class="lead text-secondary fs-6" style="white-space: pre-line;">@Model.Description</p>
        </div>
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
            <h4 class="fw-bold text-dark mb-4"><i class="bi bi-clock-history text-primary me-2"></i>Programme de la journée</h4>
            <div class="timeline ps-3 border-start border-3 border-warning">
                @if (Model.AgendaItems.Any())
                {
                    foreach (var item in Model.AgendaItems)
                    {
                        <div class="position-relative mb-4 ps-4">
                            <span class="position-absolute top-0 start-0 translate-middle p-2 bg-warning border border-light rounded-circle" style="left: -2px !important;"></span>
                            <div class="small fw-bold text-warning text-uppercase">@item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")</div>
                            <h5 class="fw-bold text-dark mb-1">@item.Title</h5>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">Le programme détaillé sera publié très prochainement.</p>
                }
            </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 mb-4">
            <h4 class="fw-bold text-dark mb-4"><i class="bi bi-people-fill text-info me-2"></i>Intervenants & Keynotes</h4>
            <div class="row g-3">
                @if (Model.Speakers.Any())
                {
                    foreach (var speaker in Model.Speakers)
                    {
                        <div class="col-12 col-sm-6">
                            <div class="d-flex align-items-center gap-3 p-3 rounded-4 bg-light border">
                                <img src="@(string.IsNullOrEmpty(speaker.ProfileImageUrl) ? "https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=150&q=80" : speaker.ProfileImageUrl)"
                                     class="rounded-circle object-fit-cover border border-2 border-warning" width="65" height="65" alt="@speaker.FullName" />
                                <div>
                                    <h6 class="fw-bold text-dark mb-0">@speaker.FullName</h6>
                                    <p class="small text-muted mb-1">@speaker.Biography</p>
                                    @if (!string.IsNullOrEmpty(speaker.LinkedInUrl))
                                    {
                                        <a href="@speaker.LinkedInUrl" target="_blank" class="small text-primary text-decoration-none">
                                            <i class="bi bi-linkedin me-1"></i>Profil LinkedIn
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">Liste des intervenants à venir.</p>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <h4 class="fw-bold text-dark mb-3"><i class="bi bi-map-fill text-danger me-2"></i>Localisation sur la carte</h4>
            <div id="eventDetailsMap" class="rounded-4 border" style="height: 320px;"></div>
        </div>

    </div>
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-lg rounded-4 bg-white sticky-top" style="top: 90px;">
            <div class="card-body p-4">
                
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted fw-semibold">Prix du billet</span>
                    @if (Model.Price > 0)
                    {
                        <h3 class="fw-bold text-warning mb-0">@Model.Price.ToString("N0") FCFA</h3>
                    }
                    else
                    {
                        <span class="badge bg-success fs-5 px-3 py-2">GRATUIT</span>
                    }
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-muted">Capacité réservée</span>
                        <span class="fw-bold text-dark">185 / @Model.MaxCapacity places</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 10px;">
                        <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated" role="progressbar" style="width: 92.5%" aria-valuenow="92.5" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>

                <div class="d-grid gap-2 mb-4">
                    <button class="btn btn-afro btn-lg py-3 rounded-3 shadow" data-bs-toggle="modal" data-bs-target="#registerModal">
                        <i class="bi bi-ticket-detailed-fill me-2"></i> S'inscrire à cet événement
                    </button>
                </div>

                <hr>

                <div class="d-flex flex-column gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-light p-2 rounded-3 text-warning"><i class="bi bi-calendar-event fs-4"></i></div>
                        <div>
                            <div class="small text-muted">Date & Heure</div>
                            <div class="fw-bold text-dark small">@Model.StartDate.ToString("dd MMMM yyyy, HH:mm")</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-light p-2 rounded-3 text-danger"><i class="bi bi-geo-alt fs-4"></i></div>
                        <div>
                            <div class="small text-muted">Lieu</div>
                            <div class="fw-bold text-dark small">@Model.LocationAddress</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-light p-2 rounded-3 text-info"><i class="bi bi-qr-code fs-4"></i></div>
                        <div>
                            <div class="small text-muted">Billet PDF & QR Code</div>
                            <div class="fw-bold text-dark small">Envoi instantané par e-mail</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="registerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header bg-warning text-dark py-3">
                <h5 class="modal-title fw-bold"><i class="bi bi-ticket-perforated-fill me-2"></i>Inscription à @Model.Title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nom complet</label>
                        <input type="text" class="form-control" placeholder="ex: Kadiatou Traoré" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Adresse e-mail</label>
                        <input type="email" class="form-control" placeholder="kadiatou@example.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Numéro de téléphone (WhatsApp)</label>
                        <input type="tel" class="form-control" placeholder="+223 XX XX XX XX" required />
                    </div>
                    @if (Model.Price > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Mode de paiement simulé</label>
                            <select class="form-select">
                                <option>Orange Money</option>
                                <option>Wave</option>
                                <option>Moov Money</option>
                                <option>Carte Bancaire International</option>
                            </select>
                        </div>
                    }
                    <div class="d-grid mt-4">
                        <button type="button" class="btn btn-afro btn-lg" onclick="alert('Inscription réussie ! Votre billet PDF avec QR Code a été simulé.')" data-bs-dismiss="modal">
                            Confirmer & Générer mon e-Billet PDF
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const lat = @Model.Latitude;
            const lng = @Model.Longitude;

            const map = L.map('eventDetailsMap').setView([lat, lng], 14);
            L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map)
                .bindPopup('<b>@Model.Title</b><br>@Model.LocationAddress')
                .openPopup();
        });
    </script>
}
