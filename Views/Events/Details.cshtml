@model AfroEvent.Models.EventItem
@{
    ViewData["Title"] = "Présentation de l'événement";
}

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <span class="badge bg-warning text-dark mb-2">@Model.Category</span>
                            <h1 class="fw-bold mb-2">@Model.Name</h1>
                            <p class="text-muted mb-0">@Model.ShortDescription</p>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold fs-4">@Model.Price.ToString("N0") FCFA</div>
                            <div class="text-muted">@Model.AvailablePlaces places restantes</div>
                        </div>
                    </div>

                    <p class="lead">@Model.Description</p>

                    <div class="row g-4 mt-3">
                        <div class="col-md-6">
                            <h5 class="fw-bold">Programme</h5>
                            <pre class="bg-light p-3 rounded">@Model.Program</pre>
                        </div>
                        <div class="col-md-6">
                            <h5 class="fw-bold">Intervenants</h5>
                            <p>@Model.Speakers</p>
                        </div>
                    </div>

                    <div class="row g-4 mt-3">
                        <div class="col-md-6">
                            <h5 class="fw-bold">Logistique</h5>
                            <p>@Model.Logistics</p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="fw-bold">Lieu</h5>
                            <p>@Model.Location</p>
                            <p class="mb-0">Début : @Model.StartDate.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</p>
                        </div>
                    </div>

                    @if (TempData["Message"] is string message)
                    {
                        <div class="alert alert-success mt-3">@message</div>
                    }

                    <div class="mt-4 d-flex flex-wrap gap-2">
                        <form asp-action="Reserve" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning text-dark fw-bold">Réserver une place</button>
                        </form>
                        <a asp-controller="Participant" asp-action="SInscrire" asp-route-nom="@Model.Name" class="btn btn-outline-dark">S'inscrire</a>
                        <a asp-action="Index" class="btn btn-outline-dark">Retour</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold">Places restantes</h5>
                    <div class="progress mb-3" style="height: 12px;">
                        <div id="placesProgress" class="progress-bar bg-warning" role="progressbar" style="width: @(Model.AvailablePlaces * 100 / Model.Capacity)%"></div>
                    </div>
                    <p id="placesText" class="mb-0">@Model.AvailablePlaces / @Model.Capacity places disponibles</p>

                    <hr />

                    <h5 class="fw-bold">Carte interactive</h5>
                    <iframe
                        title="Carte de l'événement"
                        width="100%"
                        height="260"
                        style="border:0; border-radius: 12px;"
                        loading="lazy"
                        allowfullscreen
                        referrerpolicy="no-referrer-when-downgrade"
                        src="https://www.openstreetmap.org/export/embed.html?bbox=@(Model.Longitude - 0.01),@(Model.Latitude - 0.01),@(Model.Longitude + 0.01),@(Model.Latitude + 0.01)&layer=mapnik">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const eventId = '@Model.Id';
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/eventHub')
            .build();

        connection.on('ReceivePlacesUpdate', (updatedEventId, availablePlaces, capacity) => {
            if (updatedEventId !== eventId) return;
            const percent = Math.round((availablePlaces / capacity) * 100);
            document.getElementById('placesProgress').style.width = percent + '%';
            document.getElementById('placesText').textContent = availablePlaces + ' / ' + capacity + ' places disponibles';
        });

        connection.start().then(() => {
            connection.invoke('JoinEventGroup', eventId.toString());
        }).catch(err => console.error(err));
    </script>
}
