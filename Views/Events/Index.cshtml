@model IEnumerable<AfroEvent.ViewModels.EventFormViewModel>
@{
    ViewData["Title"] = "Catalogue des Événements";
}

<div class="text-center py-4 mb-4 bg-dark text-white rounded-4 shadow-sm p-4 position-relative overflow-hidden">
    <div class="position-relative z-1">
        <span class="badge bg-warning text-dark fw-bold px-3 py-2 text-uppercase mb-2">🌍 Plateforme Événementielle Africaine</span>
        <h1 class="display-6 fw-bold">Découvrez & Participez aux meilleurs Événements</h1>
        <p class="lead text-white-50 mx-auto" style="max-width: 650px;">Hackathons, bootcamps tech, conférences internationales et concerts. Réservez votre place en quelques clics.</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 bg-white mb-4">
    <div class="card-body p-3">
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-start-0" placeholder="Rechercher par mot-clé, ville ou lieu...">
                </div>
            </div>
            <div class="col-6 col-md-3">
                <select class="form-select bg-light">
                    <option value="">Toutes les catégories</option>
                    <option value="1">Hackathon</option>
                    <option value="2">Bootcamp</option>
                    <option value="3">Conférence</option>
                </select>
            </div>
            <div class="col-6 col-md-3">
                <select class="form-select bg-light">
                    <option value="">Tous les prix</option>
                    <option value="free">Gratuit</option>
                    <option value="paid">Payant</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    @foreach (var evt in Model)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white overflow-hidden hover-shadow transition">
                <div class="position-relative">
                    <img src="@(string.IsNullOrEmpty(evt.CoverImageUrl) ? "https://images.unsplash.com/photo-1515187029135-18ee286d815b?auto=format&fit=crop&w=600&q=80" : evt.CoverImageUrl)"
                         class="card-img-top object-fit-cover" style="height: 200px;" alt="@evt.Title" />
                    <span class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark fw-bold">@evt.CategoryName</span>
                </div>
                <div class="card-body p-4 d-flex flex-column">
                    <div class="small text-muted mb-2">
                        <i class="bi bi-calendar-event text-warning me-1"></i>@evt.StartDate.ToString("dd MMMM yyyy, HH:mm")
                    </div>
                    <h5 class="fw-bold text-dark card-title mb-2">@evt.Title</h5>
                    <p class="card-text text-secondary small text-truncate-2 mb-3">@evt.Description</p>
                    <div class="small text-muted mb-3"><i class="bi bi-geo-alt text-danger me-1"></i>@evt.LocationAddress</div>
                    
                    <div class="mt-auto pt-3 border-top d-flex align-items-center justify-content-between">
                        <div>
                            @if (evt.Price > 0)
                            {
                                <span class="fw-bold text-dark fs-5">@evt.Price.ToString("N0") <span class="fs-6 text-muted font-normal">FCFA</span></span>
                            }
                            else
                            {
                                <span class="badge bg-success bg-opacity-10 text-success fw-bold fs-6">Gratuit</span>
                            }
                        </div>
                        <a asp-controller="Events" asp-action="Details" asp-route-id="@evt.Id" class="btn btn-sm btn-afro px-3 rounded-pill">
                            Voir détails <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
